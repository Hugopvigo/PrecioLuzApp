# ═══════════════════════════════════════════
#  PrecioLuzApp · Android .gitignore
# ═══════════════════════════════════════════

# ── OS generated ──────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Hidden files & dirs ───────────────────
.*
!/.gitignore
!/.gitkeep

# ── Environment & secrets ─────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.jks
*.keystore

# ── Android build ─────────────────────────
/build
/captures
app/build/
.externalNativeBuild
.cxx
*.apk
*.aab
*.ap_
*.dex

# ── Gradle ────────────────────────────────
.gradle/
local.properties
*.hprof

# ── IDE / Editor ──────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ── Kotlin / Java ─────────────────────────
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ── Logs ──────────────────────────────────
*.log

# ── Misc ──────────────────────────────────
*.bak
*.tmp
*.orig
